# =============================================================================
#  Zepeed — Production Environment Template
#
#  Copy this file to .env and fill in every required value before running:
#    docker compose -f compose.prod.yml up -d
#
#  Lines marked [REQUIRED] must be set — the container will not start correctly
#  without them.  Lines marked [OPTIONAL] have sensible defaults.
# =============================================================================

# =============================================================================
#  APPLICATION
# =============================================================================

# [REQUIRED] Your public domain — must match the DNS A record pointing to this host.
APP_DOMAIN=zepeed.example.com

# [REQUIRED] Full URL including scheme — must match APP_DOMAIN.
APP_URL=https://zepeed.example.com

# [OPTIONAL] Display name shown in the UI and emails.
APP_NAME=Zepeed

# [REQUIRED] 32-byte base64 key.  Generate with:
#   docker run --rm marjose123/zepeed:latest php artisan key:generate --show
APP_KEY=

# [OPTIONAL] Timezone for scheduled speedtests (e.g. America/New_York, Asia/Manila).
APP_TIMEZONE=UTC

# [REQUIRED] Email address for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

# [OPTIONAL] Pin a specific release (e.g. 1.1.0).  Defaults to latest.
ZEPEED_VERSION=latest

# =============================================================================
#  DATABASE  (MariaDB 11 LTS)
# =============================================================================

# [REQUIRED] Strong random root password — not used by the app, only for DBA access.
DB_ROOT_PASSWORD=change_me_root

# [OPTIONAL] Database name.
DB_DATABASE=zepeed

# [OPTIONAL] Application database user.
DB_USERNAME=zepeed

# [REQUIRED] Strong random application password.
DB_PASSWORD=change_me_app

# =============================================================================
#  WEBSOCKETS  (Soketi)
#  These three values are shared secrets between the app and the WS server.
#  Generate random strings — they never leave your server.
# =============================================================================

# [REQUIRED] Any non-empty string.
PUSHER_APP_ID=zepeed

# [REQUIRED] Any non-empty string (used as client key).
PUSHER_APP_KEY=zepeed_key

# [REQUIRED] Any non-empty strong random string.
PUSHER_APP_SECRET=change_me_ws_secret

# =============================================================================
#  MAIL
#  Set MAIL_MAILER=log to disable outbound email during initial setup.
#  Supported mailers: smtp, mailgun, postmark, ses, resend, log
# =============================================================================

# [OPTIONAL] Mailer driver.
MAIL_MAILER=log

# SMTP settings (required when MAIL_MAILER=smtp)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
#  ADVANCED  (change only if you know what you're doing)
# =============================================================================

# [OPTIONAL] Session lifetime in minutes.
SESSION_LIFETIME=120

# =============================================================================
#  DEFAULT ADMIN ACCOUNT
#  Created automatically on first boot. Skipped on subsequent boots if the
#  email already exists — fully idempotent.
#  Change these before first launch, or update via the UI after login.
# =============================================================================

# [OPTIONAL] Display name for the default admin user.
DEFAULT_ADMIN_NAME="Zepeed Admin"

# [OPTIONAL] Login email for the default admin user.
DEFAULT_ADMIN_EMAIL=admin@zepeed.local

# [REQUIRED] Must be at least 8 characters. Change immediately after first login.
DEFAULT_ADMIN_PASSWORD=change_me_now

# [OPTIONAL] Traefik log level: DEBUG, INFO, WARN, ERROR.
TRAEFIK_LOG_LEVEL=ERROR
