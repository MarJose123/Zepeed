{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "marjose123/laravel-shadcnvue-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel starter kit",
        "laravel shadcnvue starter kit",
        "laravel shadcnvue",
        "laravel shadcnvue starter"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "MarJose Darang",
            "email": "hypernate1@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "aws/aws-sdk-php": "^3.374",
        "dedoc/scramble": "^0.13.28",
        "hexydec/agentzero": "^2.0",
        "inertiajs/inertia-laravel": "^3.0",
        "lacodix/laravel-model-filter": "^4.4",
        "laravel/fortify": "^1.33",
        "laravel/framework": "^13.0",
        "laravel/mcp": "^0.8.2",
        "laravel/prompts": "^0.3.18",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "promphp/prometheus_client_php": "^2.15",
        "pusher/pusher-php-server": "^7.2",
        "resend/resend-php": "^1.1",
        "scalar/laravel": "^0.2.1",
        "spatie/laravel-data": "^4.20.1",
        "spatie/laravel-webhook-server": "^3.10",
        "spatie/ping": "^1.2",
        "stevebauman/location": "^7.6",
        "symfony/http-client": "^8.0",
        "symfony/mailgun-mailer": "^8.0",
        "tightenco/ziggy": "^2.6"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^13.2",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.dev.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "@php artisan realtime:credentials --force",
            "bun install --ignore-scripts",
            "bun run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx --bun concurrently \"composer mailpit\" \"composer reverb\" \"@php artisan queue:listen --tries=1\" \"@php artisan schedule:work\" \"bun run dev\" --names=mailserver,reverb,queue,scheduler,vite --kill-others --prefix name -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" "
        ],
        "herd:dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx --bun concurrently -c cyan,blue,green,yellow \"composer run reverb\" \"composer run queue\" \"composer run mailpit\" \"bun run dev\" --names=reverb,queue,mailserver,dev --kill-others"
        ],
        "format:be": [
            "vendor/bin/pint --dirty"
        ],
        "format:fe": [
            "bun run format",
            "bun run lint"
        ],
        "format": [
            "@format:be",
            "@format:fe"
        ],
        "mailpit": [
            "Composer\\Config::disableProcessTimeout",
            "@php .bin/mailpit/run-mailpit.php"
        ],
        "mailpit:update": [
            "Composer\\Config::disableProcessTimeout",
            "@php .bin/mailpit/updater.php"
        ],
        "rector": [
            "vendor/bin/rector process --ansi"
        ],
        "rector:check": [
            "vendor/bin/rector process --dry-run --ansi"
        ],
        "analyse": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/phpstan analyse --memory-limit=2G --ansi"
        ],
        "test:api": [
            "@php artisan config:clear --ansi",
            "@php artisan test --testsuite=Api --stop-on-failure --ansi"
        ],
        "test:mcp": [
            "@php artisan config:clear --ansi",
            "@php artisan test --testsuite=Mcp --stop-on-failure --ansi"
        ],
        "pre-commit": [
            "@rector",
            "bun run typecheck",
            "@format",
            "@analyse",
            "@test:api",
            "@test:mcp"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.dev.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "scripts-descriptions": {
        "format:be": "Fixing the Code Style according to PER standards for the backend code",
        "format:fe": "Fixing the Code Style according to PER standards for the frontend code",
        "format": "Fixing the Code Style according to PER standards for both backend and frontend code",
        "mailpit": "Run the mailpit server for testing emails",
        "rector": "Fixing the code according to the Rector Rules",
        "rector:check": "Showing the suggested changes from Rector",
        "analyse": "Analyse the code with PHPStan code analysis",
        "pre-commit": "Run the pre-commit hooks",
        "test:mcp": "Run the MCP server tests"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
