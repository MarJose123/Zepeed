.git/
.github/
.idea/
.vscode/
.showcase/

# Environment files
.env
.env.*
!.env.prod.example

# Build and Dependency directories
node_modules/
vendor/
public/build/
public/hot/
package-lock.json

# Lock files are REQUIRED by the production build stage:
#   composer install uses composer.lock for reproducible installs
#   bun install --frozen-lockfile requires bun.lock
# Do NOT add composer.lock, bun.lock, or bun.lockb here.

# Laravel specific exclusions
storage/*.log
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/testing/*
storage/framework/views/*.php
storage/app/public/*
bootstrap/cache/*.php
database/database.sqlite

# System files
.DS_Store
Thumbs.db
